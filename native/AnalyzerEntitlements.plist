<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime required for notarization -->
    <!-- Network client: Roon WebSocket + outbound HTTP (Ollama/LLM/services) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Network server: SOOD multicast + the share/feature HTTP servers (5767/5766) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- NB: no keychain-access-groups. That entitlement is "restricted" on macOS
         and requires an embedded provisioning profile (Apple Developer portal),
         which a Developer ID build doesn't have — adding it makes the kernel
         SIGKILL the app at launch. Credential sharing with sibling apps is
         instead handled by the stable Developer ID signature (a one-time Keychain
         "Always Allow" persists across updates). -->
</dict>
</plist>
