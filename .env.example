# RoonSage Environment Variables
# Copy this file to .env and update with your actual values

# =============================================================================
# Security
# =============================================================================

# Optional: Enable HTTP Basic Auth for all endpoints.
# When set, a password is required to access the web UI and API.
# The username field is ignored; only the password is checked.
# Exempt endpoints (no auth required): GET /api/health, GET /api/art/*, GET /api/external-art
#ROONSAGE_PASSWORD=

# Roon Core Configuration
ROON_HOST=192.168.1.x
ROON_PORT=9330

# Optional: Roon token (auto-saved after first authorization in Roon → Extensions)
#ROON_TOKEN=
#ROON_CORE_ID=

# LLM Provider (anthropic, openai, gemini, ollama, or custom)
# Defaults to gemini if not set. Can also be configured in UI.
#LLM_PROVIDER=gemini

# LLM Provider API Keys (set the one matching your provider)
#ANTHROPIC_API_KEY=sk-ant-your-key-here
#OPENAI_API_KEY=sk-your-key-here
#GEMINI_API_KEY=your-gemini-key-here

# Optional: Override default models (usually auto-detected from provider)
#LLM_MODEL_ANALYSIS=gemini-2.5-flash
#LLM_MODEL_GENERATION=gemini-2.5-flash

# =============================================================================
# Local LLM Settings (experimental)
# =============================================================================

# Ollama - runs models locally via Ollama
#LLM_PROVIDER=ollama
#OLLAMA_URL=http://localhost:11434
#OLLAMA_CONTEXT_WINDOW=32768
#LLM_MODEL_ANALYSIS=llama3:8b
#LLM_MODEL_GENERATION=llama3:8b

# Custom - any OpenAI-compatible API (OpenRouter, LM Studio, etc.)
#LLM_PROVIDER=custom
#CUSTOM_LLM_URL=https://openrouter.ai/api/v1
#CUSTOM_LLM_API_KEY=sk-or-your-key-here
#CUSTOM_CONTEXT_WINDOW=32768
#LLM_MODEL_ANALYSIS=meta-llama/llama-3-8b-instruct
#LLM_MODEL_GENERATION=meta-llama/llama-3-8b-instruct

# =============================================================================
# Metadata Enrichment (optional — speeds up the enrichment pipeline)
# =============================================================================

# Skip MusicBrainz and use only Last.fm for enrichment.
# Last.fm allows 5 req/s vs MusicBrainz's 1 req/s, making a 68k-track library
# go from ~36 hours to under 1 hour. Trade-off: no MBID or release-date backfill.
# Requires LASTFM_API_KEY to be set. Recommended for large libraries (>10k tracks).
#ENRICHMENT_SKIP_MB=true

# =============================================================================
# Qobuz playlist save (optional — save generated playlists to your Qobuz account)
# =============================================================================

# The app_id is auto-extracted from the Qobuz web player — you do NOT need to
# configure it. Only email and password are required.
#QOBUZ_EMAIL=                  # Qobuz account email
#QOBUZ_PASSWORD=               # Qobuz account password

# =============================================================================
# v13.0 — Sonic exploration features (off by default; both pull large models)
# =============================================================================

# CLAP text-to-audio search. First use downloads ~600 MB to CLAP_CACHE_DIR.
#CLAP_ENABLED=true
#CLAP_MODEL=laion/larger_clap_music_and_speech
#CLAP_BATCH_SIZE=4

# Semantic lyrics search. First use downloads ~500 MB GTE-multilingual to
# HF_HOME (defaults to /app/data/.hf_cache inside the container).
#LYRICS_SEARCH_ENABLED=true
#LYRICS_MODEL=Alibaba-NLP/gte-multilingual-base

# ONNX Runtime inference (faster startup, smaller RAM footprint). Both default
# to true — the code falls back to the full PyTorch model when the ONNX files
# aren't present in ONNX_MODELS_DIR. Build the files once with the export
# scripts in `scripts/`:
#   docker compose exec roonsage python scripts/export_clap_onnx.py
#   docker compose exec roonsage python scripts/export_gte_onnx.py
#CLAP_USE_ONNX=true
#LYRICS_USE_ONNX=true
#ONNX_MODELS_DIR=/app/data/models

# =============================================================================
# Sidecar worker process (optional — offloads heavy tasks to a separate process)
# =============================================================================

# Run audio-feature analysis and metadata enrichment in a dedicated container
# so the FastAPI event loop stays responsive under heavy analysis load.
#
# Step 1: set WORKER_SIDECAR=true here so the main service skips those workers.
# Step 2: start the worker: WORKER_SIDECAR=true docker compose --profile worker up -d
#
# Default (false): everything runs in one container — original behaviour.
#WORKER_SIDECAR=false
